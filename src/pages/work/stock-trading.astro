---
import PostLayout from "@/layouts/PostLayout.astro";
import PageHeader from "@/components/elements/PageHeader.astro";
import ActionBar from "@/components/widgets/ActionBar.astro";
import SeparatorLine from "@/components/elements/SeparatorLine.astro";
---
<PostLayout
	title="StockEye — Stock Trading Platform"
	description="A full-stack stock trading simulation web app built with Node.js, SQLite, and vanilla JavaScript for CS416 Web Programming at CCSU."
	keywords="StockEye, stock trading, full-stack, Node.js, SQLite, JavaScript, web app, CS416"
>
	<div class="work article">
		<main class="work-wrapper">
			<PageHeader
				title="StockEye — Stock Trading Platform"
				tags={["Node.js", "JavaScript", "SQLite", "Full-Stack"]}
				className="mb-6 md:mb-8"
			/>
			<div class="site-container m-auto">
				<SeparatorLine />
			</div>
			<section class="article-content">
				<div class="site-container mx-auto my-8 md:my-16">
					<img
						src="/assets/works/stock-trading.jpg"
						alt="Stock market trading dashboard"
						class="w-full rounded-2xl object-cover mb-10 max-h-[400px]"
					/>
					<div>
						<p>
							StockEye is a full-stack stock trading simulation platform built as the final project for CS416 Web Programming at CCSU. Users can create accounts, log in, browse live stock data, and manage a virtual portfolio — all backed by a Node.js server and a relational SQLite database.
						</p>
						<p>Highlights</p>
						<ul>
							<li>✅ <strong>Role-Based Access Control:</strong> Three user roles (admin, staff, customer) with distinct permissions enforced at the database level.</li>
							<li>✅ <strong>Relational Database Design:</strong> 5-table SQLite schema covering Users, Stocks, Portfolios, Transactions, and AdminActions — with foreign keys, CHECK constraints, and auto-update triggers.</li>
							<li>✅ <strong>Live Stock Data:</strong> Integrated external stock API to fetch and display real market data, with responses cached in a processed JSON layer.</li>
							<li>✅ <strong>Portfolio Management:</strong> Buy/sell simulation with full transaction history tracked per user.</li>
							<li>✅ <strong>Admin Audit Logging:</strong> All administrative actions are logged to a dedicated table for accountability.</li>
							<li>✅ <strong>Multi-Page Frontend:</strong> Separate pages for landing, login, stock ticker, and portfolio view — built with vanilla HTML, CSS, and JavaScript.</li>
						</ul>
						<p><strong>Tech Stack:</strong> Node.js, SQLite, JavaScript, HTML, CSS</p>
						<p><strong>Course:</strong> CS416 Web Programming, CCSU Fall 2024</p>
					</div>
				</div>
			</section>
		</main>
	</div>
	<ActionBar logo="/assets/experiences/ccsu.png" tags={["Node.js", "SQLite", "Full-Stack"]} url="https://github.com/HenryDaley2/416FinalProject" visitLabel="View on GitHub" />
</PostLayout>
